# Optional: SerpAPI for more search results (https://serpapi.com/)
SERPAPI_KEY=

# How to send WhatsApp: whatsapp_web (your number, no API) or twilio (Business API)
SEND_METHOD=whatsapp_web

# Optional: Twilio (only when SEND_METHOD=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# How many search results to crawl per run (default 20)
CRAWL_LIMIT=20

# DuckDuckGo region: id-id (Indonesia), th-th (Thailand), sg-en (Singapore), wt-wt (no region)
SEARCH_REGION=wt-wt
