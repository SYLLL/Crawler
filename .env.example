# Optional: SerpAPI for more search results (https://serpapi.com/)
SERPAPI_KEY=

# Optional: Twilio WhatsApp (https://www.twilio.com/docs/whatsapp)
# Required for sending messages. Without this, crawler only collects leads to CSV.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# How many search results to crawl per run (default 20)
CRAWL_LIMIT=20
